# Copy to .env.local and fill in. .env.local is gitignored.

# ——— Mail (Resend) ———
# Destination inbox for enquiries:
CONTACT_TO_EMAIL=hello@tenfishlabs.com
# Verified sender on your Resend domain:
CONTACT_FROM_EMAIL=hello@tenfishlabs.com
# Resend API key (https://resend.com/ → API Keys):
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ——— Cloudflare Turnstile (optional but recommended) ———
# Site key is public and injected at build time (must be prefixed VITE_):
VITE_TURNSTILE_SITE_KEY=0xAAAAAAAAAAAAAAAAAAAAAA
# Secret key — server only. When set, /api/contact enforces verification.
TURNSTILE_SECRET_KEY=0x0000000000000000000000000000000000000000

# ——— Dev instrumentation (optional) ———
# Set to "true" in prod to see trackEvent() payloads in the browser console.
# VITE_DEBUG_EVENTS=true
